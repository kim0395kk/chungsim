# Copy to .env and set real values locally.
# Do not commit .env.

# LLM keys
GEMINI_API_KEY=
GROQ_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=

# Optional: Naver search API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Optional: Vertex AI fallback config
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL_ID=gemini-2.5-flash
# JSON string for service-account creds (optional)
VERTEX_AI_CREDENTIALS_JSON=
